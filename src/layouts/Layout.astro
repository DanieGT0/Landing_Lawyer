---
import { getImage } from "astro:assets";
import "../styles/global.css";
import { firma } from "../data/site";
import ogSource from "../assets/images/El Salvador.jpeg";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${firma.nombreLargo} — El Salvador`,
  description = "Bufete de abogados y notarios en San Salvador: derecho corporativo, servicios notariales, propiedad intelectual, trámites para extranjeros, derecho de familia y constitución de sociedades SAS. Consulta jurídica gratis por WhatsApp, respuesta en 24 horas.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = await getImage({ src: ogSource, width: 1200, height: 630, fit: "cover" });
const ogImageURL = new URL(ogImage.src, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LegalService",
  name: firma.nombre,
  alternateName: firma.nombreLargo,
  description,
  image: ogImageURL.toString(),
  url: Astro.site?.toString(),
  telephone: firma.telefono,
  email: firma.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: firma.direccion,
    addressLocality: "San Salvador",
    addressCountry: "SV",
  },
  areaServed: "El Salvador",
  priceRange: "$$",
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="es_SV" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="theme-color" content="#f9f7f3" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline>
      // Aplica el tema antes del primer paint (sin flash).
      // Si el cliente ya eligió manualmente (navy/midnight) se respeta;
      // si no, se sigue la preferencia del sistema (claro = navy, oscuro = midnight).
      try {
        var t = localStorage.getItem("theme");
        if (t !== "navy" && t !== "midnight") {
          t = window.matchMedia("(prefers-color-scheme: dark)").matches ? "midnight" : "navy";
        }
        document.documentElement.dataset.theme = t;
      } catch (e) {}
    </script>
    <title>{title}</title>
  </head>
  <body class="bg-cream text-body-text font-body antialiased">
    <div class="scroll-progress" data-scroll-progress></div>
    <div class="grain" aria-hidden="true"></div>
    <div class="spotlight" data-spotlight aria-hidden="true"></div>
    <slot />
  </body>
</html>
