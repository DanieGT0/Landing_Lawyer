---
import "../styles/global.css";
import { firma } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${firma.nombreLargo} — El Salvador`,
  description = "Asesoría y litigio legal en El Salvador: derecho corporativo, notarial, laboral y de familia. Consulta gratis por WhatsApp o correo, respuesta en 24 horas.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#f9f7f3" />
    <script is:inline>
      // Aplica el tema antes del primer paint (sin flash).
      // Si el cliente ya eligió manualmente (navy/midnight) se respeta;
      // si no, se sigue la preferencia del sistema (claro = navy, oscuro = midnight).
      try {
        var t = localStorage.getItem("theme");
        if (t !== "navy" && t !== "midnight") {
          t = window.matchMedia("(prefers-color-scheme: dark)").matches ? "midnight" : "navy";
        }
        document.documentElement.dataset.theme = t;
      } catch (e) {}
    </script>
    <title>{title}</title>
  </head>
  <body class="bg-cream text-body-text font-body antialiased">
    <div class="scroll-progress" data-scroll-progress></div>
    <div class="grain" aria-hidden="true"></div>
    <div class="spotlight" data-spotlight aria-hidden="true"></div>
    <slot />
  </body>
</html>
