---
import { areas } from "../data/site";
import Icon from "./Icon.astro";

// Duplicamos para que el loop 3D infinito tenga suficientes tarjetas
const loop = [...areas, ...areas];
---

<section id="areas" class="relative overflow-hidden bg-cream py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <div class="mb-14 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="reveal eyebrow mb-5" data-reveal>Qué hacemos</p>
        <h2 class="reveal font-display text-4xl leading-tight text-header md:text-5xl" data-reveal>
          Áreas de práctica
        </h2>
      </div>
      <p class="reveal max-w-sm text-body-text" data-reveal>
        Seis frentes donde acompañamos a personas y empresas en El Salvador con
        criterio técnico y trato directo. Arrastra o desliza para explorar.
      </p>
    </div>
  </div>

  <!-- Carrusel 3D infinito -->
  <div class="relative">
    <div class="pointer-events-none absolute inset-y-0 left-0 z-30 w-16 bg-gradient-to-r from-cream to-transparent md:w-40"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 z-30 w-16 bg-gradient-to-l from-cream to-transparent md:w-40"></div>

    <div class="c3d select-none" data-carousel3d data-gap="26">
      <div class="c3d-track" data-c3d-track>
        {
          loop.map((a, i) => (
            <article
              class="c3d-card group relative flex h-[440px] w-[320px] flex-col overflow-hidden rounded-2xl border border-line bg-surface p-7 shadow-lg shadow-black/5 sm:w-[360px]"
              aria-hidden={i >= areas.length ? "true" : undefined}
            >
              {/* barra superior de acento */}
              <span class="absolute inset-x-0 top-0 h-1 origin-left scale-x-0 bg-theme transition-transform duration-500 group-hover:scale-x-100" />

              <div class="flex items-start justify-between">
                <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-theme/10 text-theme transition-colors duration-300 group-hover:bg-theme group-hover:text-white">
                  <Icon name={a.icon} class="h-7 w-7" />
                </div>
                <span class="font-display text-3xl leading-none text-line-2">
                  {String((i % areas.length) + 1).padStart(2, "0")}
                </span>
              </div>

              <h3 class="mt-6 font-display text-2xl leading-snug text-header">{a.titulo}</h3>
              <p class="mt-3 text-sm leading-relaxed text-body-text">{a.resumen}</p>

              <ul class="mt-auto space-y-2.5 border-t border-line pt-5">
                {a.puntos.slice(0, 3).map((p) => (
                  <li class="flex items-start gap-2.5 text-sm text-body-text">
                    <Icon name="arrow" class="mt-0.5 h-4 w-4 shrink-0 text-theme" />
                    {p}
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </div>

  <p class="mt-10 text-center text-xs uppercase tracking-[0.2em] text-body-text/60">
    Arrastra · rueda del mouse · o deja que gire solo
  </p>
</section>

<style>
  .c3d {
    position: relative;
    width: 100%;
    touch-action: pan-y;
  }
  .c3d-track {
    display: flex;
    gap: 26px;
  }
  .c3d-card {
    flex-shrink: 0;
  }
</style>
