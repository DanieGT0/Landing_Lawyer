---
import { Image } from "astro:assets";
import logo from "../assets/images/logo.png";
import { firma, navLinks, whatsappLink } from "../data/site";
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-500"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-6 py-4 md:px-8">
    <a href="#inicio" class="flex items-center gap-2.5">
      <Image
        src={logo}
        alt={firma.nombre}
        class="site-logo h-20 w-auto"
        loading="eager"
      />
      <span class="font-display text-xl tracking-tight text-header">
        {firma.nombre}
      </span>
    </a>

    <nav class="hidden items-center gap-8 lg:flex">
      {
        navLinks.map((l) => (
          <a
            href={l.href}
            class="link-swipe text-sm font-medium text-header/80 transition-colors hover:text-theme"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <div
        id="theme-bar"
        class="flex items-center gap-0.5 rounded-full border border-line bg-surface p-1 shadow-sm"
        role="group"
        aria-label="Modo de color"
      >
        <button
          type="button"
          id="theme-btn-navy"
          data-theme-id="navy"
          aria-label="Modo claro"
          class="theme-bar-btn flex h-8 w-8 items-center justify-center rounded-full text-header/70 transition-colors"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <circle cx="12" cy="12" r="4.5" />
            <path d="M12 2.5v2.2M12 19.3v2.2M4.2 4.2l1.6 1.6M18.2 18.2l1.6 1.6M2.5 12h2.2M19.3 12h2.2M4.2 19.8l1.6-1.6M18.2 5.8l1.6-1.6" />
          </svg>
        </button>
        <button
          type="button"
          id="theme-btn-midnight"
          data-theme-id="midnight"
          aria-label="Modo oscuro"
          class="theme-bar-btn flex h-8 w-8 items-center justify-center rounded-full text-header/70 transition-colors"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <path d="M20 14.5A8.5 8.5 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5z" />
          </svg>
        </button>
      </div>

      <a
        href={whatsappLink()}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden rounded-full bg-header px-5 py-2.5 text-sm font-medium text-cream transition-colors hover:bg-theme sm:inline-block"
      >
        Consulta gratis
      </a>
    </div>
  </div>
</header>

<style>
  .site-logo {
    transition: filter 0.3s;
  }
  :global([data-theme="midnight"]) .site-logo,
  :global([data-theme="onyx"]) .site-logo {
    filter: brightness(0) invert(1);
  }
  .theme-bar-btn[aria-pressed="true"] {
    background: var(--color-theme);
    color: #fff;
  }
</style>

<script>
  const header = document.getElementById("site-header");
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 30) {
        header.classList.add("bg-cream/90", "backdrop-blur-md", "shadow-sm", "border-b", "border-line");
      } else {
        header.classList.remove("bg-cream/90", "backdrop-blur-md", "shadow-sm", "border-b", "border-line");
      }
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  const KEY = "theme";
  const html = document.documentElement;
  const themeButtons = document.querySelectorAll<HTMLButtonElement>(".theme-bar-btn");

  function markActive(id: string) {
    themeButtons.forEach((b) => {
      b.setAttribute("aria-pressed", String(b.dataset.themeId === id));
    });
  }

  function currentTheme(): string {
    return (
      html.dataset.theme ||
      (window.matchMedia("(prefers-color-scheme: dark)").matches ? "midnight" : "navy")
    );
  }

  markActive(currentTheme());

  themeButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.dataset.themeId || "navy";
      html.dataset.theme = id;
      localStorage.setItem(KEY, id);
      markActive(id);
    });
  });
</script>
