---
import { Image } from "astro:assets";
import logo from "../assets/images/logo.png";
import { firma, navLinks, whatsappLink } from "../data/site";
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-500"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-6 py-4 md:px-8">
    <a href="#inicio" class="flex items-center gap-2.5">
      <Image
        src={logo}
        alt={firma.nombre}
        class="site-logo h-14 w-auto"
        loading="eager"
      />
      <span class="font-display text-xl tracking-tight text-header">
        {firma.nombre}
      </span>
    </a>

    <nav class="hidden items-center gap-8 lg:flex">
      {
        navLinks.map((l) => (
          <a
            href={l.href}
            class="link-swipe text-sm font-medium text-header/80 transition-colors hover:text-theme"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <a
      href={whatsappLink()}
      target="_blank"
      rel="noopener noreferrer"
      class="hidden rounded-full bg-header px-5 py-2.5 text-sm font-medium text-cream transition-colors hover:bg-theme sm:inline-block"
    >
      Consulta gratis
    </a>
  </div>
</header>

<style>
  .site-logo {
    transition: filter 0.3s;
  }
  :global([data-theme="midnight"]) .site-logo,
  :global([data-theme="onyx"]) .site-logo {
    filter: brightness(0) invert(1);
  }
</style>

<script>
  const header = document.getElementById("site-header");
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 30) {
        header.classList.add("bg-cream/90", "backdrop-blur-md", "shadow-sm", "border-b", "border-line");
      } else {
        header.classList.remove("bg-cream/90", "backdrop-blur-md", "shadow-sm", "border-b", "border-line");
      }
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
