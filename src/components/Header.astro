---
import { firma, navLinks, whatsappLink } from "../data/site";
---

<header class="fixed inset-x-0 top-0 z-50 px-4 pt-4 md:px-8 md:pt-6">
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4">
    <!-- Left pill: brand -->
    <a
      href="#"
      class="glass flex items-center gap-2.5 rounded-full py-2.5 pl-4 pr-5"
    >
      <span
        class="flex h-6 w-6 items-center justify-center rounded-sm bg-gold font-display text-sm font-semibold text-ink"
      >
        A
      </span>
      <span class="font-display text-base tracking-tight text-bone">
        {firma.nombre}
      </span>
    </a>

    <!-- Center pill: links -->
    <div class="glass hidden items-center gap-1 rounded-full px-2 py-2 lg:flex">
      {
        navLinks.map((l) => (
          <a
            href={l.href}
            class="rounded-full px-4 py-1.5 text-sm text-bone-dim transition-colors hover:bg-bone/5 hover:text-bone"
          >
            {l.label}
          </a>
        ))
      }
    </div>

    <!-- Right: CTA -->
    <a
      href={whatsappLink()}
      target="_blank"
      rel="noopener noreferrer"
      class="rounded-full bg-gold px-5 py-2.5 text-sm font-medium text-ink transition-transform hover:scale-[1.03]"
    >
      Consulta gratis
    </a>
  </nav>
</header>
