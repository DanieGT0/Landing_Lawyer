---
import { Image } from "astro:assets";
import library from "../assets/images/library.jpg";
import { firma, areas, navLinks, whatsappLink } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden bg-header pt-20 pb-10 text-cream">
  <!-- Imagen de fondo tenue -->
  <Image
    src={library}
    alt=""
    class="pointer-events-none absolute inset-0 h-full w-full object-cover opacity-[0.10]"
    widths={[800, 1600]}
    sizes="100vw"
    loading="lazy"
  />
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-header via-header/90 to-header/70"></div>

  <div class="relative mx-auto max-w-7xl px-6 md:px-8">
    <div class="grid gap-12 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <a href="#inicio" class="font-display text-2xl tracking-tight text-cream">
          {firma.nombre}<span class="text-theme">.</span>
        </a>
        <p class="mt-4 max-w-xs text-sm text-cream/60">
          {firma.nombreLargo}. Asesoría y litigio en El Salvador con criterio
          técnico y trato directo.
        </p>
        <a
          href={whatsappLink()}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-flex items-center gap-2 rounded-full bg-theme px-5 py-2.5 text-sm font-medium text-white transition-transform hover:scale-[1.03]"
        >
          Consulta gratis
        </a>
      </div>

      <div>
        <h3 class="mb-4 text-xs uppercase tracking-[0.2em] text-cream/50">Navegación</h3>
        <ul class="space-y-2.5">
          {navLinks.map((l) => (
            <li>
              <a href={l.href} class="link-swipe text-sm text-cream/80 hover:text-cream">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-xs uppercase tracking-[0.2em] text-cream/50">Áreas</h3>
        <ul class="space-y-2.5">
          {areas.slice(0, 5).map((a) => (
            <li>
              <a href="#areas" class="link-swipe text-sm text-cream/80 hover:text-cream">{a.titulo}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-center justify-between gap-3 border-t border-cream/10 pt-8 text-xs uppercase tracking-wide text-cream/50 md:flex-row">
      <span>© {year} {firma.nombre} — Todos los derechos reservados</span>
      <span>{firma.direccion}</span>
    </div>
  </div>
</footer>
