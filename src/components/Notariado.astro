---
import { notariado } from "../data/site";
import Icon from "./Icon.astro";
---

<section class="relative border-y border-line bg-ink-2 py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <div class="mb-14 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div>
        <p
          class="reveal mb-4 flex items-center gap-3 text-xs uppercase tracking-[0.35em] text-gold-soft"
          data-reveal
        >
          <span class="h-px w-10 bg-gold/60"></span>
          Notaría
        </p>
        <h2 class="reveal font-display text-4xl leading-[0.95] text-bone md:text-5xl" data-reveal>
          Servicios notariales
        </h2>
      </div>
      <p class="reveal max-w-sm text-bone-dim" data-reveal>
        Actos autorizados por la Corte Suprema de Justicia. Los trámites más
        solicitados, resueltos con rapidez y seguridad jurídica.
      </p>
    </div>

    <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {
        notariado.map((item, i) => (
          <li
            class="reveal glass group flex items-center gap-3 rounded-lg px-5 py-4 transition-colors hover:border-gold/40"
            data-reveal
            style={`transition-delay:${(i % 3) * 60}ms`}
          >
            <Icon name="seal" class="h-5 w-5 shrink-0 text-gold" />
            <span class="text-sm text-bone">{item}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
