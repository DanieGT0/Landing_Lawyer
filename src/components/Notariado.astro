---
import { notariado } from "../data/site";
import Icon from "./Icon.astro";
---

<section class="relative border-y border-line bg-surface py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <div class="mb-14 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="reveal eyebrow mb-5" data-reveal>Notaría</p>
        <h2 class="reveal font-display text-4xl leading-tight text-header md:text-5xl" data-reveal>
          Servicios notariales
        </h2>
      </div>
      <p class="reveal max-w-sm text-body-text" data-reveal>
        Actos autorizados por la Corte Suprema de Justicia. Los trámites más
        solicitados, resueltos con rapidez y seguridad jurídica.
      </p>
    </div>

    <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {
        notariado.map((item, i) => (
          <li
            class="reveal group flex items-center gap-3 rounded-xl border border-line bg-cream px-5 py-4 transition-colors hover:border-theme/50"
            data-reveal
            style={`transition-delay:${(i % 3) * 60}ms`}
          >
            <Icon name="seal" class="h-5 w-5 shrink-0 text-theme" />
            <span class="text-sm font-medium text-header">{item}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
