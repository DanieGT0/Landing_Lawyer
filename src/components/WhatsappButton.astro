---
import { whatsappLink } from "../data/site";
import Icon from "./Icon.astro";
---

<a
  href={whatsappLink()}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
  class="group fixed bottom-6 right-6 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-theme text-white shadow-lg shadow-black/30 transition-transform hover:scale-110 md:bottom-8 md:right-8"
>
  <span class="absolute inset-0 rounded-full bg-theme/40 animate-ping"></span>
  <Icon name="whatsapp" class="relative h-7 w-7" />
</a>
