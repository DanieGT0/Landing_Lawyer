---
// Modal de video reutilizable. Se abre con cualquier elemento [data-lightbox]
// que tenga data-src="/ruta.mp4".
---
<div
  id="video-lightbox"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-header/80 p-6 backdrop-blur-sm"
  aria-hidden="true"
>
  <button
    id="lightbox-close"
    aria-label="Cerrar video"
    class="absolute right-6 top-6 flex h-11 w-11 items-center justify-center rounded-full border border-cream/30 text-cream transition-colors hover:bg-cream hover:text-header"
  >
    <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
      <path d="M6 6l12 12M18 6L6 18" />
    </svg>
  </button>

  <div class="relative aspect-video w-full max-w-4xl overflow-hidden rounded-2xl shadow-2xl">
    <video id="lightbox-video" class="h-full w-full object-cover" controls playsinline>
      <source src="" type="video/mp4" />
    </video>
  </div>
</div>

<script>
  const modal = document.getElementById("video-lightbox");
  const video = document.getElementById("lightbox-video") as HTMLVideoElement | null;
  const source = video?.querySelector("source");
  const closeBtn = document.getElementById("lightbox-close");

  function open(src: string) {
    if (!modal || !video || !source) return;
    source.setAttribute("src", src);
    video.load();
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    video.play().catch(() => {});
  }

  function close() {
    if (!modal || !video) return;
    video.pause();
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    modal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  document.querySelectorAll<HTMLElement>("[data-lightbox]").forEach((el) => {
    el.addEventListener("click", (e) => {
      e.preventDefault();
      const src = el.dataset.src || "/intro.mp4";
      open(src);
    });
  });

  closeBtn?.addEventListener("click", close);
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) close();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") close();
  });
</script>
