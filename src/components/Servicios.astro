---
const servicios = [
  {
    n: "01",
    title: "Civil y contratos",
    text: "Redacción, revisión y litigio de contratos civiles, arrendamientos y responsabilidad civil.",
  },
  {
    n: "02",
    title: "Mercantil y societario",
    text: "Constitución de sociedades, fusiones, cumplimiento normativo y asesoría corporativa continua.",
  },
  {
    n: "03",
    title: "Laboral",
    text: "Defensa patronal y de trabajadores, liquidaciones, despidos y negociación colectiva.",
  },
  {
    n: "04",
    title: "Familia y sucesiones",
    text: "Divorcios, pensiones alimenticias, herencias y procesos de familia con acompañamiento cercano.",
  },
];
---

<section id="servicios" class="bg-paper py-28 md:py-36">
  <div class="mx-auto max-w-7xl px-6 md:px-10">
    <div class="mb-16 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <h2 class="reveal font-display text-5xl leading-none md:text-6xl" data-reveal>
        Áreas de
        <br />
        práctica.
      </h2>
      <p class="reveal max-w-sm text-ink-soft/80" data-reveal>
        Cuatro frentes donde acompañamos a personas y empresas con criterio
        técnico y trato directo — sin intermediarios, sin letra pequeña.
      </p>
    </div>

    <div class="grid divide-y divide-line border-y border-line">
      {
        servicios.map((s, i) => (
          <div
            class="reveal group grid grid-cols-[auto_1fr] items-start gap-6 py-10 transition-colors md:grid-cols-[100px_1fr_1fr] md:items-center md:gap-10"
            data-reveal
            style={`transition-delay:${i * 80}ms`}
          >
            <span class="font-display text-2xl text-accent-soft/70">
              {s.n}
            </span>
            <h3 class="font-display text-3xl transition-transform duration-500 group-hover:translate-x-2 md:text-4xl">
              {s.title}
            </h3>
            <p class="col-span-2 text-ink-soft/75 md:col-span-1">{s.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
