---
import { Image } from "astro:assets";
import marble from "../assets/images/marble-dark.jpg";

const WHATSAPP_NUMBER = "50370000000"; // TODO: reemplazar con número real (código país + número, sin +)
const waMessage = encodeURIComponent(
  "Hola, quisiera agendar una consulta legal.",
);
---

<section
  class="relative flex min-h-screen items-end overflow-hidden bg-ink grain"
>
  <Image
    src={marble}
    alt=""
    class="absolute inset-0 h-full w-full object-cover opacity-45"
    widths={[640, 1280, 1920, 2400]}
    sizes="100vw"
    loading="eager"
  />
  <div
    class="absolute inset-0 bg-gradient-to-t from-ink via-ink/70 to-ink/20"
  ></div>

  <div class="relative mx-auto w-full max-w-7xl px-6 pb-24 pt-40 md:px-10">
    <p
      class="reveal mb-6 text-sm uppercase tracking-[0.35em] text-accent-soft"
      data-reveal
    >
      Despacho jurídico — desde 2010
    </p>

    <h1
      class="reveal font-display text-[13vw] leading-[0.9] tracking-tight text-paper md:text-[7.5vw]"
      data-reveal
    >
      Defendemos
      <br />
      lo que <span class="italic text-accent-soft">importa.</span>
    </h1>

    <div
      class="reveal mt-10 flex flex-col gap-4 border-t border-paper/15 pt-8 sm:flex-row sm:items-center sm:justify-between"
      data-reveal
    >
      <p class="max-w-md text-balance text-paper/70">
        Asesoría legal en materia civil, mercantil, laboral y de familia.
        Primera consulta sin costo — respondemos en menos de 24 horas.
      </p>

      <div class="flex shrink-0 gap-3">
        <a
          href={`https://wa.me/${WHATSAPP_NUMBER}?text=${waMessage}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-3 text-sm font-medium uppercase tracking-wide text-paper transition-transform hover:scale-105"
        >
          WhatsApp
        </a>
        <a
          href="#contacto"
          class="inline-flex items-center gap-2 rounded-full border border-paper/30 px-6 py-3 text-sm uppercase tracking-wide text-paper transition-colors hover:border-paper"
        >
          Escribir consulta
        </a>
      </div>
    </div>
  </div>
</section>
