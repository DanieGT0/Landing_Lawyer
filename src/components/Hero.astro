---
import courthouse from "../assets/images/El Salvador.jpeg";
import { firma, whatsappLink } from "../data/site";
import Icon from "./Icon.astro";
---

<section
  id="inicio"
  class="relative flex min-h-[92svh] items-center overflow-hidden bg-cream pt-28 pb-16 md:pt-32"
>
  <!-- Full-bleed moving video background (visible en todo el hero) -->
  <video
    class="pointer-events-none absolute inset-0 h-full w-full object-cover"
    autoplay
    loop
    muted
    playsinline
    preload="metadata"
    poster={courthouse.src}
    aria-hidden="true"
  >
    <source src="/hero.mp4" type="video/mp4" />
  </video>

  <!-- Overlay: crema a la izquierda (texto legible) → casi transparente a la derecha (video más claro) -->
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-r from-cream via-cream/70 to-transparent"></div>
  <div class="pointer-events-none absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-cream to-transparent"></div>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-cream/80 to-transparent"></div>

  <div class="relative mx-auto w-full max-w-7xl px-6 md:px-8">
    <div class="max-w-2xl">
      <p class="reveal eyebrow mb-6" data-reveal>{firma.tagline}</p>

      <h1 class="font-display text-5xl leading-[1.05] text-header sm:text-6xl md:text-7xl" data-kinetic>
        <span class="kinetic-line">Defensa legal</span>
        <span class="kinetic-line">con <span class="text-theme italic">criterio.</span></span>
      </h1>

      <p class="reveal mt-8 max-w-md text-lg leading-relaxed text-header/80" data-reveal>
        Asesoría y litigio en materia corporativa, notarial y de familia. Brindamos respaldo legal a salvadoreños y extranjeros dentro del país. Primera consulta sin costo — respondemos en menos de 24 horas.
      </p>

      <div class="reveal mt-9 flex flex-wrap items-center gap-3" data-reveal>
        <a
          href={whatsappLink()}
          target="_blank"
          rel="noopener noreferrer"
          data-magnetic
          class="inline-flex items-center gap-2 rounded-full bg-theme px-6 py-3.5 text-sm font-medium text-white transition-transform hover:scale-[1.03]"
        >
          <Icon name="whatsapp" class="h-4 w-4" />
          Escribir por WhatsApp
        </a>
        <a
          href="#contacto"
          class="inline-flex items-center gap-2 rounded-full border border-line-2 bg-cream/60 px-6 py-3.5 text-sm font-medium text-header backdrop-blur transition-colors hover:border-theme hover:text-theme"
        >
          Enviar consulta
          <Icon name="arrow" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </div>

  <!-- Floating badge sobre el video (derecha) -->
  <div class="absolute bottom-10 right-6 hidden items-center gap-3 rounded-xl border border-line bg-surface/95 px-5 py-4 shadow-lg shadow-black/10 backdrop-blur md:right-8 md:flex">
    <span class="flex h-11 w-11 items-center justify-center rounded-lg bg-theme/10 text-theme">
      <Icon name="shield" class="h-6 w-6" />
    </span>
    <div>
      <p class="font-display text-sm text-header">Confidencialidad</p>
      <p class="text-xs text-body-text">profesional garantizada</p>
    </div>
  </div>
</section>
