---
import { Image } from "astro:assets";
import courthouse from "../assets/images/El Salvador.jpeg";
import { stats } from "../data/site";
---

<section id="despacho" class="relative overflow-hidden bg-cream py-24 md:py-32">
  <div class="mx-auto grid max-w-7xl gap-14 px-6 md:grid-cols-2 md:px-8">
    <div class="reveal relative order-2 md:order-1" data-reveal>
      <div class="relative aspect-[4/5] overflow-hidden rounded-2xl shadow-xl shadow-black/10">
        <Image
          src={courthouse}
          alt="Fachada de palacio de justicia con columnas"
          class="ken-burns h-full w-full object-cover"
          widths={[480, 800, 1200]}
          sizes="(min-width: 768px) 45vw, 90vw"
        />
      </div>
      <!-- gold corner accent -->
      <div class="absolute -right-4 -top-4 h-24 w-24 rounded-tr-2xl border-r-2 border-t-2 border-theme"></div>
    </div>

    <div class="order-1 flex flex-col justify-center md:order-2">
      <p class="reveal eyebrow mb-5" data-reveal>El despacho</p>
      <h2 class="reveal font-display text-3xl leading-tight text-header md:text-5xl" data-reveal>
        Criterio jurídico claro, sin lenguaje que confunda
      </h2>
      <p class="reveal mt-8 max-w-lg text-body-text" data-reveal>
        Somos un equipo reducido de abogados y notarios litigantes. Cada caso lo
        lleva directamente quien lo firma — no hay pasantes intermediarios ni
        respuestas automáticas. Explicamos cada paso del proceso en términos que
        cualquier cliente entiende.
      </p>

      <dl class="reveal mt-12 grid grid-cols-2 gap-8 border-t border-line pt-10 sm:grid-cols-4" data-reveal>
        {
          stats.map((s) => (
            <div>
              <dt
                class="font-display text-4xl text-theme"
                data-counter={s.valor}
                data-suffix={s.sufijo}
              >
                0{s.sufijo}
              </dt>
              <dd class="mt-1.5 text-xs uppercase leading-tight tracking-wide text-body-text">
                {s.label}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</section>
