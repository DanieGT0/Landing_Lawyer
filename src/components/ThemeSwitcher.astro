---
import { temas } from "../data/site";
---

<!-- Selector de tema (demo para el cliente). Botón flotante abajo-izquierda. -->
<div class="fixed bottom-6 left-6 z-[90] print:hidden">
  <!-- Panel -->
  <div
    id="theme-panel"
    class="mb-3 hidden w-72 origin-bottom-left rounded-2xl border border-line bg-surface p-4 shadow-2xl shadow-black/20"
  >
    <div class="mb-3 flex items-center justify-between">
      <p class="font-display text-base text-header">Elige un tema</p>
      <button id="theme-close" aria-label="Cerrar" class="text-body-text hover:text-header">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>
    <div class="grid grid-cols-2 gap-2">
      {
        temas.map((t) => (
          <button
            class="theme-option group flex items-center gap-2.5 rounded-xl border border-line p-2.5 text-left transition-colors hover:border-theme"
            data-theme-id={t.id}
          >
            <span
              class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-black/10"
              style={`background:${t.bg}`}
            >
              <span class="h-3.5 w-3.5 rounded-full" style={`background:${t.accent}`} />
            </span>
            <span class="text-xs font-medium text-header">{t.nombre}</span>
          </button>
        ))
      }
    </div>
    <p class="mt-3 text-[11px] leading-snug text-body-text">
      Vista previa. El cliente decide; luego se fija la paleta final.
    </p>
  </div>

  <!-- Toggle button -->
  <button
    id="theme-toggle"
    aria-label="Cambiar tema"
    class="flex h-13 items-center gap-2 rounded-full border border-line bg-surface px-4 py-3 text-sm font-medium text-header shadow-lg shadow-black/15 transition-transform hover:scale-[1.04]"
  >
    <svg viewBox="0 0 24 24" class="h-5 w-5 text-theme" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="12" cy="12" r="9" />
      <path d="M12 3a9 9 0 0 0 0 18c1.7 0 2-1.3 1-2.3-.8-.8-.3-2.2.9-2.2H17a4 4 0 0 0 4-4c0-4.5-4-6.5-9-6.5z" fill="currentColor" stroke="none" opacity="0.15"/>
      <circle cx="8.5" cy="10" r="1" fill="currentColor" stroke="none"/>
      <circle cx="12" cy="8" r="1" fill="currentColor" stroke="none"/>
      <circle cx="15.5" cy="10" r="1" fill="currentColor" stroke="none"/>
    </svg>
    Tema
  </button>
</div>

<script>
  const KEY = "theme";
  const html = document.documentElement;
  const toggle = document.getElementById("theme-toggle");
  const panel = document.getElementById("theme-panel");
  const close = document.getElementById("theme-close");

  function apply(id: string) {
    if (id) html.dataset.theme = id;
    else delete html.dataset.theme;
    localStorage.setItem(KEY, id);
    markActive(id);
  }

  function markActive(id: string) {
    document.querySelectorAll<HTMLElement>(".theme-option").forEach((b) => {
      const on = (b.dataset.themeId || "") === id;
      b.classList.toggle("border-theme", on);
      b.classList.toggle("ring-2", on);
      b.classList.toggle("ring-theme", on);
    });
  }

  // Aplicar guardado (el Layout ya lo aplica pre-paint; esto sincroniza el marcado)
  markActive(localStorage.getItem(KEY) || "");

  toggle?.addEventListener("click", () => panel?.classList.toggle("hidden"));
  close?.addEventListener("click", () => panel?.classList.add("hidden"));

  document.querySelectorAll<HTMLElement>(".theme-option").forEach((btn) => {
    btn.addEventListener("click", () => apply(btn.dataset.themeId || ""));
  });
</script>
